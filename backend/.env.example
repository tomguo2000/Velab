# ============================================================
# FOTA 智能诊断平台 - Backend 环境配置
# ============================================================
# 使用方法：cp .env.example .env && vim .env
# ⚠️ .env 包含敏感信息，严禁提交到 Git 仓库
#
# 本文件中的每个变量都对应 backend/config.py 中 Settings 类的字段
# pydantic-settings 会自动从 .env 文件加载（大小写不敏感）
# ============================================================

# ────────────────────────────────────────────────────────────
# 1. 基础配置
# ────────────────────────────────────────────────────────────

# [可选] 项目显示名称（用于日志和 API 文档标题）
# 对应 config.py → Settings.PROJECT_NAME
PROJECT_NAME="FOTA 智能诊断平台"

# ────────────────────────────────────────────────────────────
# 2. 部署模式（决定 LLM 访问方式）
# ────────────────────────────────────────────────────────────
# 对应 config.py → Settings.DEPLOYMENT_MODE (DeploymentMode 枚举)
#   A = 场景 A — 国内部署，通过本地 LiteLLM Gateway 中转访问海外 LLM API
#   B = 场景 B — 海外部署，直连 Claude / OpenAI 官方 API（或中转服务）

# [必填] 部署模式：A 或 B
DEPLOYMENT_MODE=A

# ────────────────────────────────────────────────────────────
# 3. LLM API 配置 — 场景 A（LiteLLM 中转）
# ────────────────────────────────────────────────────────────
# 仅在 DEPLOYMENT_MODE=A 时生效
# config.py → LLM_BASE_URL 属性会返回 LITELLM_BASE_URL
# config.py → LLM_API_KEY 属性会返回 LITELLM_API_KEY
# llm.py → AsyncOpenAI(base_url=LLM_BASE_URL, api_key=LLM_API_KEY)

# [场景A必填] LiteLLM Proxy 地址（需与 gateway/.env 中 HOST:PORT 一致）
# 对应 config.py → Settings.LITELLM_BASE_URL
LITELLM_BASE_URL=http://127.0.0.1:4000/v1

# [场景A必填] LiteLLM 访问密钥（与 gateway 的 LITELLM_MASTER_KEY 或 Virtual Key 对应）
# 对应 config.py → Settings.LITELLM_API_KEY
LITELLM_API_KEY=sk-fota-virtual-key

# ────────────────────────────────────────────────────────────
# 4. LLM API 配置 — 场景 B（直连供应商 / 中转服务）
# ────────────────────────────────────────────────────────────
# 仅在 DEPLOYMENT_MODE=B 时生效
# config.py → LLM_API_KEY 属性优先返回 ANTHROPIC_API_KEY，其次 OPENAI_API_KEY

# [场景B必填] Anthropic API Key（申请：https://console.anthropic.com/）
# 对应 config.py → Settings.ANTHROPIC_API_KEY
ANTHROPIC_API_KEY=

# [场景B可选] Anthropic 默认模型（未设置时代码默认 claude-haiku-4-5-20251001）
# 建议填入你账号实际可用的 model id（可从报错或模型列表中获取）
# ANTHROPIC_DEFAULT_MODEL=claude-haiku-4-5-20251001

# [场景B必填] OpenAI API Key（申请：https://platform.openai.com/api-keys）
# 对应 config.py → Settings.OPENAI_API_KEY
OPENAI_API_KEY=

# [场景B可选] 供应商自定义端点 — 用于接入中转服务（如 NewAPI / OneAPI）
# 对应 config.py → Settings.ANTHROPIC_API_BASE（默认 https://api.anthropic.com）
# 对应 config.py → Settings.OPENAI_API_BASE（默认 https://api.openai.com/v1）
#
# ⚠️ 重要：当 OPENAI_API_BASE 设为非官方默认地址时，
#    config.py 的 LLM_BASE_URL 属性会自动将其作为全局 base_url 透传给 OpenAI SDK
#    这意味着场景 B 下只需设置 OPENAI_API_BASE 即可让所有请求走中转
#
# 取消注释并填入中转地址即可启用：
# ANTHROPIC_API_BASE=https://your-newapi.com
# OPENAI_API_BASE=https://your-newapi.com/v1

# ────────────────────────────────────────────────────────────
# 5. PostgreSQL 数据库配置
# ────────────────────────────────────────────────────────────
# 用于存储案件元数据 (cases)、诊断事件 (diagnosis_events)、
# 日志文件记录 (raw_log_files)、已确认诊断 (confirmed_diagnosis)
# config.py 自动拼接为 DATABASE_URL 和 DATABASE_URL_ASYNC

# [必填] PostgreSQL 用户名
# 对应 config.py → Settings.POSTGRES_USER
POSTGRES_USER=postgres

# [必填] PostgreSQL 密码（生产环境请使用强密码）
# 对应 config.py → Settings.POSTGRES_PASSWORD
POSTGRES_PASSWORD=fota_password

# [必填] 数据库名称
# 对应 config.py → Settings.POSTGRES_DB
POSTGRES_DB=fota_db

# [可选] 数据库主机地址（默认 localhost）
# 对应 config.py → Settings.POSTGRES_HOST
POSTGRES_HOST=localhost

# [可选] 数据库端口（默认 5432）
# 对应 config.py → Settings.POSTGRES_PORT
POSTGRES_PORT=5432

# ────────────────────────────────────────────────────────────
# 6. Redis 配置
# ────────────────────────────────────────────────────────────
# 用于 Arq 异步任务队列（日志解析）、语义缓存、会话管理

# [可选] Redis 主机地址（默认 localhost）
# 对应 config.py → Settings.REDIS_HOST
REDIS_HOST=localhost

# [可选] Redis 端口（默认 6379）
# 对应 config.py → Settings.REDIS_PORT
REDIS_PORT=6379

# [可选] Redis 密码（无密码则留空）
# 对应 config.py → Settings.REDIS_PASSWORD
REDIS_PASSWORD=

# ────────────────────────────────────────────────────────────
# 7. 编排器配置
# ────────────────────────────────────────────────────────────

# [可选] 是否启用 SSE 流式响应（true/false，默认 false）
# 对应 config.py → Settings.ORCHESTRATOR_STREAM
ORCHESTRATOR_STREAM=true

# ────────────────────────────────────────────────────────────
# 8. 存储配置
# ────────────────────────────────────────────────────────────

# [可选] 应用数据根目录（日志文件、工作区、评测数据等）
# 对应 config.py → Settings.STORAGE_ROOT
STORAGE_ROOT=/opt/fota-backend/data

# ────────────────────────────────────────────────────────────
# 9. Workspace（诊断工作区沙盒）配置
# ────────────────────────────────────────────────────────────
# Agent 运行时通过 Markdown 文件持久化中间状态（notes.md / todo.md）

# [可选] 是否启用 Markdown 工作区（true/false，默认 true）
# 对应 config.py → Settings.WORKSPACE_ENABLED
WORKSPACE_ENABLED=true

# [可选] 工作区总容量上限，单位 MB（默认 1024）
# 对应 config.py → Settings.WORKSPACE_MAX_SIZE_MB
WORKSPACE_MAX_SIZE_MB=1024

# [可选] Agent 是否调用 LLM 生成诊断结果（true/false，默认 true）
# - true : 各 Agent 优先调用 LLM，LLM 不可用时自动降级到 mock/规则结果
# - false: 强制全局 mock，适用于离线测试、CI 环境或无 API Key 时
# 对应 config.py → Settings.AGENTS_USE_LLM
AGENTS_USE_LLM=true

# [可选] 启用 Embedding 向量检索（需先运行 scripts/ingest_embeddings.py 预计算索引）
# - true : 使用 OpenAI Embedding API 做真实语义检索（需 OPENAI_API_KEY）
# - false: 使用 TF-IDF baseline（默认，无需额外 API Key）
# 对应 config.py → Settings.AGENTS_USE_EMBEDDINGS
AGENTS_USE_EMBEDDINGS=false

# [可选] 预计算 Embedding 索引存放目录（相对于 backend/data/）
# 对应 config.py → Settings.VECTOR_INDEX_DIR
VECTOR_INDEX_DIR=indexes/vector

# [安全] CORS 允许来源（逗号分隔，生产环境必须设置为具体域名，禁止留空或使用 *）
# 示例（生产）: ALLOWED_ORIGINS=https://fota.example.com,https://admin.example.com
# 对应 config.py → Settings.ALLOWED_ORIGINS
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ────────────────────────────────────────────────────────────
# 10. 文档切块配置（doc_retrieval Agent 使用）
# ────────────────────────────────────────────────────────────
# DocRetrievalAgent 在扫描 data/docs/ 目录时，对大文档进行滑动窗口切块，
# 每个 chunk 作为独立检索单元以提升召回率。

# [可选] 滑动窗口每块目标字符数（默认 500）
# 对应 config.py → Settings.DOC_CHUNK_SIZE
# DOC_CHUNK_SIZE=500

# [可选] 相邻 chunk 重叠字符数（默认 80）
# 增大可减少跨块关键词丢失，但会产生更多 chunk
# 对应 config.py → Settings.DOC_CHUNK_OVERLAP
# DOC_CHUNK_OVERLAP=80

# [可选] 短文档直接入库阈值（字符数，默认 600）
# 小于此值的文档不切块，直接作为单条记录检索
# 对应 config.py → Settings.DOC_CHUNK_INLINE_THRESHOLD
# DOC_CHUNK_INLINE_THRESHOLD=600

# ────────────────────────────────────────────────────────────
# 11. 运维脚本辅助配置 (仅初始化脚本使用)
# ────────────────────────────────────────────────────────────
# 以下变量不被应用主进程直接读取。

# [脚本专用] MinIO 端点 (scripts/init_minio.sh 初始化用)
# MINIO_ENDPOINT=http://localhost:9000
# MINIO_ACCESS_KEY=admin
# MINIO_SECRET_KEY=password
